# QuantSys Configuration

# Database
DATABASE_PATH=data/quantsys.db

# LLM Provider (anthropic or openai)
LLM_PROVIDER=anthropic

# Anthropic settings (for LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# OpenAI-compatible settings (for LLM_PROVIDER=openai)
# Supports any provider with OpenAI-compatible API (OpenAI, Azure, local LLMs, etc.)
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1  # Optional: custom base URL
OPENAI_MODEL=gpt-4

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/quantsys.log

# Data Collection
AKSHARE_TIMEOUT=30
AKSHARE_RETRIES=3

# Backtest
DEFAULT_INITIAL_CASH=1000000
DEFAULT_COMMISSION_RATE=0.0003
DEFAULT_SLIPPAGE=0.0001
