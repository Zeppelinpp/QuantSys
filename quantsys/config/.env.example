# QuantSys Configuration

# Database
DATABASE_PATH=data/quantsys.db

# LLM API
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/quantsys.log

# Data Collection
AKSHARE_TIMEOUT=30
AKSHARE_RETRIES=3

# Backtest
DEFAULT_INITIAL_CASH=1000000
DEFAULT_COMMISSION_RATE=0.0003
DEFAULT_SLIPPAGE=0.0001
